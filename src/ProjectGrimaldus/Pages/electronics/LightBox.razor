@code {

    private bool _displaySlideshow;

    private int _currentSlideShowItem = 0;

    private readonly string[] _imgUrls =
    {
        "images/lightbox/lightbox-earlydays-1.jpg",
        "images/lightbox/lightbox-theatrechase-1.jpg",
        "images/lightbox/lightbox-rainbow-1.jpg",
        "images/lightbox/lightbox-gif-1.gif",
    };

    private void DisplaySlideshow()
    {
        _displaySlideshow = !_displaySlideshow;
    }

    private void PreviousSlideshowItem()
    {
        _currentSlideShowItem--;
        if (_currentSlideShowItem < 0)
            _currentSlideShowItem = _imgUrls.Length - 1;
    }

    private void NextSlideshowItem()
    {
        _currentSlideShowItem++;
        if (_currentSlideShowItem >= _imgUrls.Length)
            _currentSlideShowItem = 0;
    }
}